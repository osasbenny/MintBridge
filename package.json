{
  "name": "MintBridge",
  "version": "1.0.0",
  "description": "Modern crypto-to-fiat and gift-card liquidation platform",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "web:dev": "pnpm -F web dev",
    "web:build": "pnpm -F web build",
    "api:dev": "pnpm -F api dev",
    "api:build": "pnpm -F api build",
    "mobile:dev": "pnpm -F mobile dev",
    "mobile:build": "pnpm -F mobile build"
  },
  "keywords": [
    "fintech",
    "crypto",
    "fiat",
    "gift-card",
    "africa",
    "nigeria"
