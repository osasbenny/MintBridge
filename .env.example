# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mintbridge
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=mintbridge
DATABASE_PASSWORD=password
DATABASE_NAME=mintbridge

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=3600

# API
API_PORT=3001
API_HOST=localhost
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=MintBridge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Email Service (mock/provider)
EMAIL_SERVICE=mock
EMAIL_FROM=noreply@mintbridge.com

# SMS Service (mock/provider)
SMS_SERVICE=mock

# File Upload
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Admin
ADMIN_EMAIL=admin@mintbridge.com
ADMIN_PASSWORD=admin123

# Crypto/Payment Providers (mock)
CRYPTO_PROVIDER=mock
PAYOUT_PROVIDER=mock
